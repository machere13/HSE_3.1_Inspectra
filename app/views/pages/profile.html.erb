<div class="PageProfile">
  <%= render 'shared/wrappers/W_PageHeader' %>
  <section class="PageProfile-Section-Main">
    <div class="PageProfile-Section-Content-Left">
      <div class="PageProfile-Section-Title">
        <div class="PageProfile-Header">
          <div class="PageProfile-Avatar-Wrapper">
            <% if @user.avatar.attached? %>
              <%= image_tag url_for(@user.avatar), alt: @user.name || @user.email, class: 'PageProfile-Avatar' %>
            <% elsif @user.avatar.present? %>
              <img src="<%= @user.avatar %>" alt="<%= @user.name || @user.email %>" class="PageProfile-Avatar" />
            <% else %>
              <div class="PageProfile-Avatar PageProfile-Avatar--placeholder"></div>
            <% end %>
            <%= form_with url: update_avatar_path, method: :patch, local: true, multipart: true, class: 'PageProfile-Avatar-Form' do |f| %>
              <%= f.file_field :avatar, accept: 'image/*', class: 'PageProfile-Avatar-Input', id: 'avatar-upload' %>
              <label for="avatar-upload" class="PageProfile-Avatar-Label">
                <span class="text-caption"><%= @user.avatar.attached? || @user.avatar.present? ? t('pages.profile.avatar.change') : t('pages.profile.avatar.upload') %></span>
              </label>
            <% end %>
          </div>
          <div class="PageProfile-Info-Plugs">
            <%= render 'pages/profile/M_ProfileInfoPlug', text: "#{@user.name.presence || t('pages.profile.no_name')}" %>
            <% if @user.game_role.present? %>
              <%= render 'pages/profile/M_ProfileInfoPlug', text: "#{t('pages.profile.game_role')}: #{@user.game_role_label}" %>
            <% else %>
              <%= link_to select_game_role_path, class: 'PageProfile-Info-Link' do %>
                <%= render 'pages/profile/M_ProfileInfoPlug', text: t('pages.profile.choose_game_role') %>
              <% end %>
            <% end %>
            <% if @user.level %>
              <%= render 'pages/profile/M_ProfileInfoPlug', text: "#{t('pages.profile.level')} #{@user.level_number}: #{@user.level.name}" %>
            <% end %>
            <% if @user.current_title %>
              <%= render 'pages/profile/M_ProfileInfoPlug', text: "#{t('pages.profile.titles.title')}: #{@user.current_title.name}" %>
            <% end %>
          </div>
          <% if @user.next_level %>
            <div class="PageProfile-LevelProgress">
              <div class="PageProfile-LevelProgress-Header text-p-3">
                <span><%= t('pages.profile.xp_label') %>: <%= @user.experience_points %></span>
                <span><%= t('pages.profile.xp_to_next', xp: @user.xp_remaining_to_next_level, level: @user.next_level.number) %></span>
              </div>
              <div class="PageProfile-LevelProgress-Bar" role="progressbar" aria-valuenow="<%= @user.level_progress_percent %>" aria-valuemin="0" aria-valuemax="100">
                <div class="PageProfile-LevelProgress-Bar-Fill" style="width: <%= @user.level_progress_percent %>%"></div>
              </div>
            </div>
          <% end %>
          <% if @user.game_role.present? %>
            <%= link_to t('pages.profile.change_game_role'), select_game_role_path, class: 'A_TextButton text-p-3' %>
          <% end %>
        </div>
      </div>
      <%= render 'pages/profile/M_ProfileContentPlug', info: "Достижения" %>

      <div class="PageProfile-Titles">
        <h3 class="text-h4"><%= t('pages.profile.titles.title') %></h3>
        <% if @available_titles.present? %>
          <p class="text-p-3"><%= t('pages.profile.titles.section_hint') %></p>
          <div class="PageProfile-Titles-Grid">
            <% @available_titles.each do |title| %>
              <% is_current = @user.current_title_id == title.id %>
              <%= form_with url: select_title_path, method: :patch, local: true, class: 'PageProfile-TitleForm' do %>
                <%= hidden_field_tag :title_id, title.id %>
                <button type="submit"
                        class="PageProfile-TitleCard <%= 'PageProfile-TitleCard--Current' if is_current %>"
                        <%= 'disabled' if is_current %>>
                  <span class="PageProfile-TitleCard-Name text-p-2"><%= title.name %></span>
                  <% if title.description.present? %>
                    <span class="PageProfile-TitleCard-Desc text-p-3"><%= title.description %></span>
                  <% end %>
                  <% if is_current %>
                    <span class="PageProfile-TitleCard-Badge text-caption"><%= t('pages.profile.titles.selected') %></span>
                  <% end %>
                </button>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-p-3"><%= t('pages.profile.titles.no_titles') %></p>
        <% end %>
      </div>

      <%= render 'shared/atoms/A_Button', label: "Настройки профиля" %>
    </div>
    <div class="PageProfile-Section-Content-Right">
      <%= render 'pages/profile/M_ProfileContentPlug', info: "Статистика" %>
      <div class="PageProfile-Statistic-Rows">
        <%= render 'pages/profile/M_ProfileStatisticRow', label: "Всего достижений", value: "150" %>
        <%= render 'pages/profile/M_ProfileStatisticRow', label: "Завершено", value: "100" %>
        <%= render 'pages/profile/M_ProfileStatisticRow', label: "В процессе", value: "50" %>
      </div>
      <%= render 'pages/profile/M_ProfileDonutChart', completed: 100, in_progress: 50 %>
    </div>
  </section>
</div>
