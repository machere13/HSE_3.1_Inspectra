<div class="PageInteractive" data-session-token="<%= @session_token %>">
  <%= render 'shared/wrappers/W_PageHeader' %>
  <section class="PageInteractive-Section">
    <div class="PageInteractive-Header">
      <%= link_to t('pages.interactive.back_to_list'), interactives_path, class: 'A_TextButton text-p-3' %>
      <h2 class="PageInteractive-Title"><%= @interactive.title %></h2>
      <p class="PageInteractive-Description text-p-2"><%= @interactive.description %></p>
      <div class="PageInteractive-Meta text-caption">
        <%= t('achievement_categories.' + @interactive.category) %> ·
        XP: <%= @interactive.xp_reward %><% if current_user.specialty_category == @interactive.category %> (+15% бонус класса)<% end %> ·
        <%= t('pages.interactives.difficulty', n: @interactive.difficulty) %>
      </div>
    </div>

    <% if @already_completed %>
      <div class="PageInteractive-CompletedBanner text-p-2">
        <%= t('pages.interactive.already_completed') %>
      </div>
    <% end %>

    <div class="PageInteractive-Body">
      <%= render partial: "interactives/kinds/#{@interactive.kind}",
                 locals: { interactive: @interactive, variant: @variant, already_completed: @already_completed, attempts_left: @attempts_left, max_attempts: @max_attempts } %>
    </div>

    <%= form_with url: submit_interactive_path(@interactive.key), method: :post, local: true, class: 'PageInteractive-Form' do %>
      <%= render 'shared/atoms/A_Input', name: 'answer', type: 'text', required: true, autocomplete: 'off', placeholder: t('pages.interactive.answer_placeholder'), max_width: '420px' %>
      <%= render 'shared/atoms/A_Button', type: 'submit', label: t('pages.interactive.submit') %>
    <% end %>
  </section>
</div>
