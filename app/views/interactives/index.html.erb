<div class="PageInteractives">
  <%= render 'shared/wrappers/W_PageHeader' %>
  <section class="PageInteractives-Section">
    <div class="PageInteractives-Header">
      <h2 class="PageInteractives-Title"><%= t('pages.interactives.title') %></h2>
      <p class="PageInteractives-Description text-p-2"><%= t('pages.interactives.description') %></p>
    </div>

    <% Interactive::CATEGORIES.each do |category| %>
      <% list = @interactives.select { |i| i.category == category } %>
      <% next if list.empty? %>
      <div class="PageInteractives-CategoryGroup">
        <h3 class="PageInteractives-CategoryTitle text-h4"><%= t("achievement_categories.#{category}") %></h3>
        <div class="PageInteractives-Cards">
          <% list.each do |interactive| %>
            <% completed = @completed_keys.include?(interactive.key) %>
            <%= link_to interactive_path(interactive.key), class: "PageInteractives-Card #{'PageInteractives-Card--Completed' if completed}" do %>
              <span class="PageInteractives-Card-Title text-h4"><%= interactive.title %></span>
              <span class="PageInteractives-Card-Desc text-p-3"><%= interactive.description %></span>
              <span class="PageInteractives-Card-Meta text-caption">
                XP: <%= interactive.xp_reward %> · <%= t('pages.interactives.difficulty', n: interactive.difficulty) %>
                <% if completed %> · <%= t('pages.interactives.completed_badge') %><% end %>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>
</div>
