<%
  endpoint = case interactive.key
             when 'dev_diving.network_spy'      then "/api/v1/interactive_props/spy?seed=#{variant&.seed}"
             when 'dev_diving.missing_cookie'   then nil
             when 'legacy.echo_of_past'         then "/api/v0/echo?seed=#{variant&.seed}"
             when 'it_errors.data_race'         then nil
             when 'it_errors.memory_leak'       then nil
             when 'it_security.unsecured_keys'  then "/api/v1/interactive_props/profile/2?seed=#{variant&.seed}"
             end
  cookie_name = variant&.payload&.dig('cookie_name')
  cookie_value = variant&.payload&.dig('cookie_value')
%>

<div class="PageInteractive-Scene">
  <p class="text-p-2">
    Открой <strong>DevTools</strong> (F12 или Ctrl+Shift+I) → вкладка <strong>Network</strong>.
    Ответ нужно достать оттуда.
  </p>

  <% if interactive.key == 'dev_diving.missing_cookie' && cookie_name %>
    <p class="text-p-3">
      Перейди в <strong>Application → Cookies → http://localhost:3000</strong>, добавь поле:
    </p>
    <ul class="PageInteractive-Code">
      <li>Name: <code><%= cookie_name %></code></li>
      <li>Value: <code><%= cookie_value %></code></li>
    </ul>
    <button type="button" class="A_Button" data-interactive-cookie-check
            data-cookie-name="<%= cookie_name %>"
            data-cookie-value="<%= cookie_value %>"
            data-expected-token="<%= variant&.expected_answer %>">
      <span class="A_Button-Content text-button">Проверить куку</span>
    </button>
    <p class="text-p-3" data-cookie-feedback></p>
  <% elsif interactive.key == 'it_errors.data_race' %>
    <p class="text-p-3">
      Нажми кнопку — параллельно полетят два запроса. <strong>Первый ответ</strong> (быстрый) содержит нужный токен.
      Медленный приходит с задержкой и его легко спутать.
    </p>
    <button type="button" class="A_Button" data-interactive-race
            data-fast="/api/v1/interactive_props/race/fast?seed=<%= variant&.seed %>"
            data-slow="/api/v1/interactive_props/race/slow?seed=<%= variant&.seed %>">
      <span class="A_Button-Content text-button">Запустить гонку</span>
    </button>
  <% elsif interactive.key == 'it_errors.memory_leak' %>
    <p class="text-p-3">
      Нажми «Запустить процесс» — на странице появится утечка через setInterval.
      Найди его ID в DevTools → Performance/Memory или в <code>window.__intervalsLog</code>.
    </p>
    <button type="button" class="A_Button" data-interactive-leak
            data-target-id="<%= variant&.payload&.dig('interval_id') %>">
      <span class="A_Button-Content text-button">Запустить процесс</span>
    </button>
    <p class="text-caption" data-leak-feedback>Интервалы не запущены</p>
  <% elsif endpoint %>
    <p class="text-p-3">Нажми кнопку — улетит запрос. Найди его в Network, открой <strong>Response</strong>.</p>
    <button type="button" class="A_Button" data-interactive-fetch
            data-endpoint="<%= endpoint %>">
      <span class="A_Button-Content text-button">Сделать запрос</span>
    </button>
  <% end %>

  <% if variant&.hint.present? %>
    <details class="PageInteractive-Hint">
      <summary class="text-p-3">Подсказка</summary>
      <p class="text-p-3"><%= variant.hint %></p>
    </details>
  <% end %>

  <% if current_user&.game_role_priest? && interactive.category == 'legacy' && endpoint %>
    <p class="text-p-3 PageInteractive-RolePerk">
      <strong>Перк Жреца:</strong> устаревший эндпоинт сразу подсвечен — <code><%= endpoint %></code>
    </p>
  <% end %>

  <% if current_user&.game_role_hunter? && interactive.key == 'dev_diving.blind_in_dom' %>
    <p class="text-p-3 PageInteractive-RolePerk">
      <strong>Перк Охотника:</strong> ищи Detached узлы через DevTools → Memory → Heap snapshot. После него — <code>$0</code> в консоли.
    </p>
  <% end %>

  <% if Rails.env.development? && variant %>
    <p class="text-caption PageInteractive-Stub-Note">Dev-ответ: <code><%= variant.expected_answer %></code></p>
  <% end %>
</div>
